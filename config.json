{
  "defaultHomeserver": 0,
  "homeserverList": [
    "blackmarket.coa",
    "matrix.org"
  ],
  "allowCustomHomeservers": true,

  "blackout": {
    "backendBaseUrl": "http://localhost:8000",
    "backendWsUrl": "ws://localhost:8000/ws",
    "steganography": {
      "enabled": true,
      "defaultCarrierFormat": "png",
      "maxEmbedPayloadKB": 1024,
      "autoDecodeOnDownload": true
    }
  },

  "featuredCommunities": {
    "openAsDefault": false,
    "spaces": [
      "#blackout:matrix.org"
    ],
    "rooms": [
      "#blackout:matrix.org"
    ],
    "servers": ["blackmarket.coa", "matrix.org"]
  },

  "hashRouter": {
    "enabled": true,
    "basename": "/"
  }
}
